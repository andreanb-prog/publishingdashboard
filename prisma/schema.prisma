// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  apiKey        String?        // Claude API key (encrypted)
  mailerLiteKey String?        // MailerLite API key
  // Writing Notebook
  anthropicApiKey           String?    // User's own Anthropic API key (encrypted)
  anthropicKeyAddedAt       DateTime?
  writingOnboardingComplete Boolean    @default(false)
  books         Json?          // My Books: [{title, asin, category, series, bookNumber}]
  columnPrefs   Json?          // Per-page column visibility: { meta: ['spend', 'clicks', ...] }
  goals         Json?          // Channel goals: { kdp_royalties: 500, meta_ctr: 15, ... }
  layoutPrefs   Json?          // Per-page section order: { overview: ['channel-cards', 'action-plan'], ... }
  onboardingDismissed Boolean  @default(false)
  // Author profile
  penName                 String?
  preferredGreetingName   String?
  genreCategory  String?
  genreSubgenre  String?
  referralSource String?
  // Meta Ads
  metaAccessToken  String?
  metaAdAccountId  String?
  metaTokenExpires DateTime?
  metaLastSync     DateTime?
  // Stripe subscription
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?   // "trialing" | "active" | "canceled" | "past_due" | "incomplete"
  subscriptionPlan     String?   // "regular" | "fpa"
  trialEndsAt          DateTime?
  promoCodes    UserPromoCode[]
  accounts      Account[]
  sessions      Session[]
  bookCatalog   Book[]
  rankLogs              RankLog[]
  roasLogs              RoasLog[]
  pinterestLogs         PinterestLog[]
  analyses              Analysis[]
  feedback              Feedback[]
  listBuildingLogs      ListBuildingLog[]
  bookFunnelDownloads   BookFunnelDownload[]
  bookfunnelWebhookSecret String?
  inboundEmailAddress     String?   // Postmark inbound address for swap auto-detection
  launches      Launch[]
  swapEntries   SwapEntry[]
  swapPolicies  SwapPolicy[]
  authorLists   AuthorList[]
  uploadLogs    UploadLog[]
  writingNotebooks WritingNotebook[]
  createdAt     DateTime       @default(now())
}

model Book {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  asin         String?
  seriesName   String?
  seriesOrder  Int?
  isLeadMagnet Boolean   @default(false)
  coverUrl     String?   @db.Text
  pubDate      DateTime?
  sortOrder             Int       @default(0)
  excludeFromDashboard  Boolean   @default(false)
  // Launch Planner & MCP context fields
  launchDate      DateTime?
  phase           String?   // "pre-order" | "launch" | "post-launch" | "evergreen"
  colorCode       String?
  tropeNotes      String?   // free-text tropes (launch planner legacy field)
  compAuthors     String?
  targetWordCount Int?
  // Book Bible fields
  genre                String?
  subgenre             String?
  tropes               String[]
  customTropes         String[]
  blurb                String?   @db.Text
  hookLines            String[]
  characterNotes       String?   @db.Text
  moodNotes            String?   @db.Text
  compTitles           String[]
  targetReader         String?
  manuscriptText       String?   @db.Text
  manuscriptSummary    String?   @db.Text
  manuscriptUploadedAt DateTime?
  bibleUpdatedAt       DateTime? @updatedAt
  createdAt             DateTime  @default(now())

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RankLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      String   // 'MOLR' | 'FDMBP' | custom ASIN
  asin      String
  rank      Int
  category  String?  // null = overall BSR; set = subcategory name
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, book])
}

model RoasLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  spend     Float
  earnings  Float
  roas      Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PinterestLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekEnding  DateTime
  impressions Int      @default(0)
  saves       Int      @default(0)
  clicks      Int      @default(0)
  pinCount    Int      @default(0)
  saveRate    Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String   // e.g. "2026-03"
  data      Json     // Full parsed + analyzed data
  createdAt DateTime @default(now())

  @@index([userId, month])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "bug" or "idea"
  message   String
  page      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ListBuildingLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignName String
  spend        Float
  subscribers  Int
  startDate    DateTime
  endDate      DateTime
  notes        String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model BookFunnelDownload {
  id           String   @id @default(cuid())
  userId       String
  email        String
  firstName    String?
  lastName     String?
  bookTitle    String
  bookId       String?
  downloadedAt DateTime
  confirmed    Boolean  @default(false)
  landingPage  String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PromoCode {
  id              String          @id @default(cuid())
  code            String          @unique
  description     String
  discountPercent Int?            // null = free
  discountedPrice Float?          // fixed price override (e.g. 17.00)
  maxUses         Int?            // null = unlimited
  usedCount       Int             @default(0)
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  userPromoCodes  UserPromoCode[]
}

model UserPromoCode {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  appliedAt   DateTime  @default(now())

  @@unique([userId, promoCodeId])
  @@index([userId])
}

model LaunchTemplate {
  id              String   @id @default(cuid())
  name            String
  channel         String   // "Ads" | "Email" | "Creative" | "Social"
  daysFromLaunch  Int      // negative = before launch, positive = after
  description     String
  actionType      String?  // "copy" | "brief" | "review" | null
  actionPrompt    String?  // the Claude prompt to fire when action button clicked
  phase           String   // "pre-order" | "launch" | "post-launch" | "evergreen"
  createdAt       DateTime @default(now())
}

model LaunchTask {
  id           String   @id @default(cuid())
  userId       String
  bookId       String?
  templateId   String?
  name         String
  channel      String
  phase        String
  dueDate      DateTime
  status       String   @default("not_started") // "not_started" | "in_progress" | "done" | "skipped"
  actionType   String?
  actionPrompt String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model UserStreak {
  id               String    @id @default(cuid())
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastCheckInDate  DateTime?
  freezesAvailable Int       @default(0)
  totalCheckIns    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model StreakEvent {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  actionType String   // "task_complete" | "spend_log" | "check_in" | "upload" | "claude_query"
  createdAt  DateTime @default(now())

  @@index([userId])
}

model HookTracker {
  id          String    @id @default(cuid())
  userId      String
  bookId      String?
  hook        String    @db.Text
  trope       String?
  format      String?
  channel     String?
  status      String    @default("NEW") // "NEW" | "TESTING" | "WINNER" | "PAUSED"
  ctr         Float?
  cpc         Float?
  spend       Float?
  impressions Int?
  clicks      Int?
  testDate    DateTime?
  nextVariant String?   @db.Text
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([bookId])
}

model DecisionsLog {
  id        String   @id @default(cuid())
  userId    String
  bookId    String?
  phase     String?
  summary   String
  context   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bookId])
}

model Creative {
  id            String   @id @default(cuid())
  userId        String
  bookId        String?
  name          String
  variant       String?
  phase         String   // "pre-order" | "launch" | "post-launch" | "evergreen"
  angle         String?  // "emotional" | "tension" | "trope-stack" | "social-proof" | "passage-quote"
  format        String   // "static-image" | "reel" | "carousel" | "story"
  sizes         String[] // ["1080x1080", "1080x1920"]
  status        String   @default("briefed") // "briefed" | "in-canva" | "ready" | "live" | "paused" | "cut"
  thumbnailUrl  String?
  brief         String?
  hookText      String?
  captionCopy   String?
  headlineCopy  String?
  targeting     String?  // "cold" | "warm" | "retarget" | "newsletter"
  ctr           Float?
  cpc           Float?
  spend         Float?
  impressions   Int?
  clicks        Int?
  costPerResult Float?
  adAccountId   String?
  metaAdId      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([bookId])
}

model Campaign {
  id             String   @id @default(cuid())
  userId         String
  bookId         String?
  name           String
  phase          String
  objective      String
  status         String   @default("draft") // "draft" | "active" | "paused" | "ended"
  dailyBudget    Float?
  metaCampaignId String?
  createdAt      DateTime @default(now())
  adSets         AdSet[]

  @@index([userId])
}

model AdSet {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  targeting   String
  audience    String?
  dailyBudget Float?
  status      String   @default("draft")
  metaAdSetId String?
  createdAt   DateTime @default(now())
  ads         Ad[]

  @@index([campaignId])
}

model Launch {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookTitle   String
  asin        String?
  phase       String    // "Pre-order" | "Launch Week" | "Evergreen" | "Custom"
  customPhase String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  status      String    @default("upcoming") // "upcoming" | "active" | "complete"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SwapEntry {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core fields
  promoType       String    // "swap" | "paid_promo"
  role            String?   // "inbound" | "outbound" — null for paid promos
  platform        String    // "bookclicker" | "bookfunnel" | "fpa" | "direct" | "fussy_librarian" | "booksweeps" | "bookbub" | "written_word_media" | "freebooksy" | "bargain_booksy" | "book_throne" | "robin_reads" | "spicy_romance_boyfriends" | "other"

  // Partner info (swaps only)
  partnerName     String?
  partnerListName String?
  partnerListSize Int?
  partnerLink     String?

  // My side
  myBook          String?   // "MOLR" | "FDMBP" | "Book3" | "ListBuilding"
  myList          String
  theirBook       String?

  // Type and timing
  swapType        String?   // "solo" | "feature" | "mention"
  promoDate       DateTime?
  confirmation    String    @default("applied") // "applied" | "approved" | "cancelled" | "complete"
  paymentType     String    @default("swap")    // "swap" | "paid"
  cost            Float     @default(0)

  // Performance
  reportedOpenRate  Float?
  reportedClickRate Float?
  clicks            Int?
  impressions       Int?
  subsGained        Int?

  // Flags
  firstSwap       Boolean   @default(false)
  overSwapFlag    Boolean   @default(false)
  qualityRating   String?   // "a" | "b" | "c" | "d"

  // Meta
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model SwapPolicy {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleName    String
  category    String   // "content_heat" | "format" | "genre" | "audience"
  appliesTo   String   // "inbound" | "outbound" | "both"
  severity    String   // "block" | "warn"
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model AuthorList {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Ad {
  id            String   @id @default(cuid())
  adSetId       String
  adSet         AdSet    @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  generatedName String
  creativeId    String?
  status        String   @default("draft")
  ctr           Float?
  cpc           Float?
  spend         Float?
  metaAdId      String?
  createdAt     DateTime @default(now())

  @@index([adSetId])
}

model UploadLog {
  id         String   @id @default(cuid())
  userId     String
  dataType   String   // "kdp" | "meta" | "kenp"
  uploadedAt DateTime @default(now())
  fileName   String?
  rowsParsed Int      @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dataType])
}

model WritingNotebookChat {
  id        String   @id @default(cuid())
  userId    String
  bookId    String?
  role      String   // 'user' | 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId, bookId, createdAt])
}

model WritingNotebook {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId       String?
  phase        String   // "setup" | "writing" | "edit" | "polish"
  section      String   // e.g. "outline", "characterBible", "styleGuide", "storySoFar", "drafts", "diagnose", "plan", "verify", "finalDrafts", "chapterMeta"
  chapterIndex Int?
  content      String   @db.Text
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([userId, bookId, phase, section, chapterIndex])
  @@index([userId, bookId])
}
