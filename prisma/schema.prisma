// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  apiKey        String?        // Claude API key (encrypted)
  mailerLiteKey String?        // MailerLite API key
  books         Json?          // My Books: [{title, asin, category, series, bookNumber}]
  columnPrefs   Json?          // Per-page column visibility: { meta: ['spend', 'clicks', ...] }
  goals         Json?          // Channel goals: { kdp_royalties: 500, meta_ctr: 15, ... }
  layoutPrefs   Json?          // Per-page section order: { overview: ['channel-cards', 'action-plan'], ... }
  onboardingDismissed Boolean  @default(false)
  // Author profile
  penName        String?
  genreCategory  String?
  genreSubgenre  String?
  referralSource String?
  // Meta Ads
  metaAccessToken  String?
  metaAdAccountId  String?
  metaTokenExpires DateTime?
  metaLastSync     DateTime?
  // Stripe subscription
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?   // "trialing" | "active" | "canceled" | "past_due" | "incomplete"
  subscriptionPlan     String?   // "regular" | "fpa"
  trialEndsAt          DateTime?
  promoCodes    UserPromoCode[]
  accounts      Account[]
  sessions      Session[]
  bookCatalog   Book[]
  rankLogs              RankLog[]
  roasLogs              RoasLog[]
  pinterestLogs         PinterestLog[]
  analyses              Analysis[]
  feedback              Feedback[]
  listBuildingLogs      ListBuildingLog[]
  bookFunnelDownloads   BookFunnelDownload[]
  bookfunnelWebhookSecret String?
  createdAt     DateTime       @default(now())
}

model Book {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  asin         String?
  seriesName   String?
  seriesOrder  Int?
  isLeadMagnet Boolean   @default(false)
  coverUrl     String?   @db.Text
  pubDate      DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RankLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      String   // 'MOLR' | 'FDMBP' | custom ASIN
  asin      String
  rank      Int
  category  String?  // null = overall BSR; set = subcategory name
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, book])
}

model RoasLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  spend     Float
  earnings  Float
  roas      Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PinterestLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekEnding  DateTime
  impressions Int      @default(0)
  saves       Int      @default(0)
  clicks      Int      @default(0)
  pinCount    Int      @default(0)
  saveRate    Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String   // e.g. "2026-03"
  data      Json     // Full parsed + analyzed data
  createdAt DateTime @default(now())

  @@index([userId, month])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "bug" or "idea"
  message   String
  page      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ListBuildingLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignName String
  spend        Float
  subscribers  Int
  startDate    DateTime
  endDate      DateTime
  notes        String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model BookFunnelDownload {
  id           String   @id @default(cuid())
  userId       String
  email        String
  firstName    String?
  lastName     String?
  bookTitle    String
  bookId       String?
  downloadedAt DateTime
  confirmed    Boolean  @default(false)
  landingPage  String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PromoCode {
  id              String          @id @default(cuid())
  code            String          @unique
  description     String
  discountPercent Int?            // null = free
  discountedPrice Float?          // fixed price override (e.g. 17.00)
  maxUses         Int?            // null = unlimited
  usedCount       Int             @default(0)
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  userPromoCodes  UserPromoCode[]
}

model UserPromoCode {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  appliedAt   DateTime  @default(now())

  @@unique([userId, promoCodeId])
  @@index([userId])
}
