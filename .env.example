# AuthorDash — Environment Variables
# Copy this to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=

# ── Auth (NextAuth) ───────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://authordash.io
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Coach (Anthropic) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── MailerLite ────────────────────────────────────────────────
MAILERLITE_API_KEY=

# ── Notion (Feedback DB) ──────────────────────────────────────
NOTION=

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=

# ── Postmark (Inbound Email / Newsletter Swaps) ───────────────
# Token is the localpart of your Postmark inbound server address
# e.g. if your address is abc123@inbound.postmarkapp.com, token = abc123
# Address shown to users: {TOKEN}@inbound.postmarkapp.com
POSTMARK_INBOUND_TOKEN=

# ── SMS Alerts (Twilio) — optional ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Admin Access ──────────────────────────────────────────────
# Comma-separated list of email addresses with admin/impersonation access
# e.g. ADMIN_EMAILS=admin@example.com,owner@example.com
ADMIN_EMAILS=

# ── Meta Ads API ──────────────────────────────────────────────
META_APP_ID=
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://authordash.io/api/meta/callback

# ── Stripe (Payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_REGULAR_PRICE_ID=
STRIPE_FPA_PRICE_ID=

# ── Cron Job Auth ─────────────────────────────────────────────
# Random secret string — must match value set in Vercel environment variables
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# ── Error Tracking (Sentry) — optional ────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
