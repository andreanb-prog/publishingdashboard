# AuthorDash — Environment Variables
# Copy this to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=

# ── Auth (NextAuth) ───────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://authordash.io
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Coach (Anthropic) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── MailerLite ────────────────────────────────────────────────
MAILERLITE_API_KEY=

# ── Notion (Feedback DB) ──────────────────────────────────────
NOTION=

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=

# ── SMS Alerts (Twilio) — optional ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Error Tracking (Sentry) — optional ────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
